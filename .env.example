APP_PORT=8080
DB_PATH=./ipn-events.db
SESSION_DURATION_HOURS=72

# Admin email — the first Google sign-in with this email becomes the admin (no invite needed).
ADMIN_EMAIL=admin@ipn.org

# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:8080/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/callback
